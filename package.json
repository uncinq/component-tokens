{
  "name": "@uncinq/component-tokens",
  "version": "1.0.1",
  "description": "Framework-agnostic CSS design tokens — component layers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uncinq/component-tokens.git"
  },
  "homepage": "https://github.com/uncinq/component-tokens#readme",
  "author": {
    "name": "Un Cinq",
    "url": "https://uncinq.dev/"
  },
  "keywords": [
    "css",
    "component-tokens",
    "custom-properties",
    "design-system",
    "design-tokens",
    "dtcg",
    "tokens"
  ],
  "files": [
    "dist/css/",
    "tokens/"
  ],
  "exports": {
    ".": "./dist/css/index.css",
    "./css/index.css": "./dist/css/index.css",
    "./css/components/*": "./dist/css/components/*",
    "./tokens/*": "./tokens/*"
  },
  "style": "./dist/css/index.css",
  "type": "module",
  "scripts": {
    "build": "style-dictionary build --config style-dictionary.config.js"
  },
  "peerDependencies": {
    "@uncinq/design-tokens": "*"
  },
  "devDependencies": {
    "style-dictionary": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
