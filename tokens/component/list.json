{
  "list": {
    "item": {
      "font": {
        "size": {
          "$value": "{fontSize.sm}",
          "$type": "dimension"
        }
      },
      "gap": {
        "$value": "{spacing.2xs}",
        "$type": "dimension"
      },
      "marker": {
        "default": { "$value": "'-'",          "$type": "string" },
        "gap":     { "$value": "{spacing.2xs}", "$type": "dimension" }
      }
    },
    "label": {
      "font": {
        "weight": {
          "$value": "{fontWeight.bold}",
          "$type": "fontWeight"
        }
      },
      "margin": {
        "y": { "$value": "{spacing.2xs}", "$type": "dimension" }
      }
    }
  }
}
