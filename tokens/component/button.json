{
  "btn": {
    "border": {
      "radius": { 
        "$value": "{radius.control}", 
        "$type": "dimension" 
      },
      "style":  { 
        "$value": "{border.style.normal}", 
        "$type": "strokeStyle" 
      },
      "width":  { 
        "$value": "{border.width.sm}", 
        "$type": "dimension" 
      }
    },
    "color": {
      "background": {
        "default": { 
          "$value": "{color.brand.default}", 
          "$type": "color" 
        },
        "hover":   { 
          "$value": "{color.brand.hover}", 
          "$type": "color" 
        }
      },
      "border": {
        "default": { 
          "$value": "{color.brand.default}", 
          "$type": "color" 
        },
        "hover":   { 
          "$value": "{color.brand.default}", 
          "$type": "color" 
        }
      },
      "text": {
        "default": { 
          "$value": "{color.text.onBrand}", 
          "$type": "color" 
        },
        "hover":   { 
          "$value": "{color.text.onBrand}", 
          "$type": "color" 
        }
      },
      "textDecoration": {
        "default": { 
          "$value": "transparent", 
          "$type": "color" 
        },
        "hover":   { 
          "$value": "transparent", 
          "$type": "color" 
        }
      }
    },
    "control": {
      "color": {
        "background": {
          "default": { 
            "$value": "{color.background.muted.default}", 
            "$type": "color" 
          },
          "hover":   { 
            "$value": "{color.background.muted.hover}", 
            "$type": "color" 
          }
        },
        "border": {
          "default": { 
            "$value": "transparent", 
            "$type": "color" 
          },
          "hover":   { 
            "$value": "transparent", 
            "$type": "color" 
          }
        },
        "text": {
          "default": { 
            "$value": "{color.text.default}", 
            "$type": "color" 
          },
          "hover":   { 
            "$value": "{color.text.default}", 
            "$type": "color" 
          }
        }
      }
    },
    "fontSize": {
      "$value": "{fontSize.sm}",
      "$type": "dimension"
    },
    "fontWeight": {
      "$value": "{fontWeight.control}",
      "$type": "fontWeight"
    },
    "gap":     { 
      "$value": "{spacing.xs}", 
      "$type": "dimension" 
    },
    "padding": {
      "inline": {
        "$value": "{spacing.control}",
        "$type": "dimension"
      },
      "block": {
        "$value": "{spacing.control}",
        "$type": "dimension"
      }
    },
    "shadow": {
      "default": { 
        "$value": "{shadow.control.default}", 
        "$type": "shadow"
      },
      "hover":   {
        "$value": "{shadow.control.hover}",
        "$type": "shadow"
      }
    },
    "textDecorationLine": {
      "$value": "underline",
      "$type": "string"
    },
    "textTransform": {
      "$value": "none",
      "$type": "string"
    },
    "transition": { 
      "$value": "{transition.color}", 
      "$type": "string" 
    }
  }
}
