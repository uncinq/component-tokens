{
  "table": {
    "cell": {
      "padding": {
        "inline": {
          "$value": "{spacing.sm}",
          "$type": "dimension"
        },
        "block": {
          "$value": "{spacing.xs}",
          "$type": "dimension"
        }
      }
    },
    "color": {
      "background": {
        "header": {
          "$value": "{color.background.muted}",
          "$type": "color"
        },
        "striped": {
          "$value": "{color.background.muted}",
          "$type": "color"
        }
      },
      "border": {
        "$value": "{color.border.default}",
        "$type": "color"
      }
    },
    "fontSize": {
      "$value": "{fontSize.sm}",
      "$type": "dimension"
    }
  }
}
