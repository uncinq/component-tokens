{
  "details": {
    "border": {
      "radius":  {
        "$value": "{radius.surface}", 
        "$type": "dimension" 
      }
    },
    "boxShadow": {
      "default": { 
        "$value": "{shadow.sm}", 
        "$type": "shadow" 
      },
      "hover":   { 
        "$value": "{shadow.md}", 
        "$type": "shadow" 
      }
    },
    "color": {
      "background": { 
        "$value": "{color.background.default}", 
        "$type": "color" 
      },
      "border": {
        "default": { 
          "$value": "{color.border.default}", 
          "$type": "color" 
        },
        "open":    { 
          "$value": "{color.border.hover}", 
          "$type": "color" 
        }
      },
      "text": {
        "$value": "{color.text.default}", 
        "$type": "color" 
      }
    },
    "icon": {
      "default": { 
        "$value": "{icon.chevron}", 
        "$type": "string" 
      },
      "size":    { 
        "$value": "{icon.size}", 
        "$type": "dimension" 
      }
    },
    "margin":  { 
      "$value": "{spacing.sm}", 
      "$type": "dimension" 
    },
    "content": {
      "padding": {
        "x": {
          "$value": "{spacing.sm}", 
          "$type": "dimension" 
        },
        "y": {
          "$value": "{spacing.sm}", 
          "$type": "dimension" 
        }
      }
    },
    "summary": {
      "fontFamily": {
        "$value": "{fontFamily.heading}",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "{fontSize.md}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.heading}",
        "$type": "fontWeight"
      },
      "padding": {
        "x": {
          "$value": "{spacing.sm}", 
          "$type": "dimension" 
        },
        "y": {
          "$value": "{spacing.sm}", 
          "$type": "dimension" 
        }
      }
    }
  }
}
