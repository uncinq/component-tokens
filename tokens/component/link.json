{
  "link": {
    "color": {
      "textDecoration": {
        "default": {
          "$value": "initial",
          "$type": "color"
        },
        "hover": {
          "$value": "transparent",
          "$type": "color"
        }
      }
    },
    "textDecorationLine": {
      "$value": "underline",
      "$type": "string"
    },
    "transition": {
      "$value": "{transition.color}",
      "$type": "string"
    }
  }
}
