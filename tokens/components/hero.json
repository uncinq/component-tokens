{
  "hero": {
    "color": {
      "background": {
        "$value": "{color.background.default}",
        "$type": "color"
      },
      "link": {
        "$value": "{color.text.default}",
        "$type": "color"
      },
      "text": {
        "$value": "{color.text.default}",
        "$type": "color"
      }
    },
    "cover": {
      "brightness": {
        "$value": 0.3,
        "$type": "number"
      }
    },
    "gap": {
      "$value": "{spacing.sm}",
      "$type": "dimension"
    },
    "minHeight": {
      "default": {
        "$value": "30vh",
        "$type": "dimension"
      },
      "tablet": {
        "$value": "40vh",
        "$type": "dimension"
      },
      "desktop": {
        "$value": "50vh",
        "$type": "dimension"
      }
    },
    "padding": {
      "block": {
        "$value": "{spacing.md}",
        "$type": "dimension"
      },
      "inline": {
        "$value": "0px",
        "$type": "dimension"
      }
    },
    "title": {
      "color": {
        "$value": "{color.text.default}",
        "$type": "color"
      },
      "fontSize": {
        "$value": "{fontSize.heading.01}",
        "$type": "dimension"
      }
    }
  }
}
