{
  "surtitle": {
    "border": {
      "radius": {
        "$value": "0",
        "$type": "dimension"
      },
      "width": {
        "$value": "0",
        "$type": "dimension"
      }
    },
    "color": {
      "default": {
        "$value": "{color.text.muted}",
        "$type": "color"
      },
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "border":     {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "fontSize": {
      "$value": "{fontSize.xs}",
      "$type": "dimension"
    },
    "fontWeight": {
      "$value": "{fontWeight.bold}",
      "$type": "fontWeight"
    },
    "letterSpacing": {
      "$value": "{letterSpacing.md}",
      "$type": "dimension"
    },
    "lineHeight": {
      "$value": "{lineHeight.normal}",
      "$type": "number"
    },
    "margin": {
      "block": {
        "$value": "0 {spacing.2xs}",
        "$type": "string"
      }
    },
    "padding": {
      "$value": "0",
      "$type": "dimension"
    },
    "textTransform": {
      "$value": "uppercase",
      "$type": "string"
    }
  }
}
